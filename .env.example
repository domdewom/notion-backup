NOTION_API_KEY=
NOTION_NOTION_VERSION=2025-09-03

# Required for official ZIP export workflow (cookie auth).
NATIVE_EXPORT_TOKEN_V2=

# Required for workspace export mode. Prefer dashed UUID format.
NOTION_SPACE_ID=

# Optional. Leave empty to send `file_token=` in the Notion cookie header.
NATIVE_EXPORT_FILE_TOKEN=

# Optional. workspace (default) or roots
OFFICIAL_EXPORT_MODE=workspace

# Optional workspace-mode tuning.
OFFICIAL_WORKSPACE_RETRYABLE_FAILURE_RETRIES=3
OFFICIAL_WORKSPACE_POLL_TIMEOUT_SECONDS=1500
OFFICIAL_WORKSPACE_UI_FALLBACK=1
OFFICIAL_WORKSPACE_UI_TIMEOUT_SECONDS=2400

# Optional comma-separated roots override (roots mode only).
OFFICIAL_EXPORT_ROOT_PAGE_IDS=

# Optional quality gates for scripts/export_official_zip.mjs
QUALITY_MIN_MD_COUNT=100
QUALITY_MIN_CSV_COUNT=10
QUALITY_MAX_DROP_PERCENT=60
OFFICIAL_ZIP_KEEP_DAYS=30
